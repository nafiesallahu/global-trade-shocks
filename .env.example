# Copy to .env and fill in your values (never commit .env)
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET=global_trade
GCS_BUCKET=your-unique-trade-lake-bucket

# Path to service account JSON (also used by dbt profiles.yml)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/creds/service-account.json

# Optional — UN Comtrade (https://comtradedeveloper.un.org/) for scripts/fetch_comtrade.py
# Same key is sent as the `subscription-key` query parameter on the `data/v1/get` endpoint.
# COMTRADE_SUBSCRIPTION_KEY=
